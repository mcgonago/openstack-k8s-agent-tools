[Unit]
Description=K8s Agent Tools Server Data Backup

[Service]
Type=oneshot
User=ospng
ExecStart=/bin/bash -c '\
    BACKUP_DIR=/home/ospng/k8s-agent-tools-server/backups/$(date +%%Y-%%m-%%d); \
    mkdir -p $BACKUP_DIR; \
    cp -a /home/ospng/k8s-agent-tools-server/data/ $BACKUP_DIR/; \
    find /home/ospng/k8s-agent-tools-server/backups/ -maxdepth 1 -mtime +30 -exec rm -rf {} +'
