{
  "error_patterns": [
    {
      "name": "API Server Connection",
      "pattern": "connection refused|unable to connect|dial tcp.*refused",
      "severity": "high",
      "category": "connectivity",
      "description": "Cannot connect to Kubernetes API server",
      "suggestions": [
        "Check cluster connectivity",
        "Verify KUBECONFIG settings",
        "Check API server health"
      ]
    },
    {
      "name": "RBAC Permission Denied",
      "pattern": "forbidden|is forbidden|cannot.*verb|not allowed",
      "severity": "high", 
      "category": "permissions",
      "description": "Insufficient RBAC permissions",
      "suggestions": [
        "Check ClusterRole and RoleBinding",
        "Verify ServiceAccount permissions",
        "Review resource access requirements"
      ]
    },
    {
      "name": "Resource Not Found",
      "pattern": "not found|NotFound|does not exist",
      "severity": "medium",
      "category": "resources",
      "description": "Required Kubernetes resource missing",
      "suggestions": [
        "Check if resource exists in cluster",
        "Verify namespace and resource names",
        "Check resource dependencies"
      ]
    },
    {
      "name": "Webhook Failure",
      "pattern": "webhook.*failed|admission.*denied|validating.*error",
      "severity": "high",
      "category": "webhooks",
      "description": "Admission webhook validation failed",
      "suggestions": [
        "Check webhook configuration",
        "Verify webhook service availability",
        "Review resource validation rules"
      ]
    },
    {
      "name": "Image Pull Error",
      "pattern": "ErrImagePull|ImagePullBackOff|pull access denied",
      "severity": "high",
      "category": "images",
      "description": "Cannot pull container image",
      "suggestions": [
        "Check image name and tag",
        "Verify registry access and credentials",
        "Check network connectivity to registry"
      ]
    },
    {
      "name": "Controller Panic",
      "pattern": "panic:|runtime error|index out of range",
      "severity": "critical",
      "category": "runtime",
      "description": "Controller panic or runtime error",
      "suggestions": [
        "Check for nil pointer dereferences",
        "Review array/slice access patterns",
        "Examine error handling logic"
      ]
    },
    {
      "name": "Reconciliation Loop",
      "pattern": "too many requests|rate limit|throttled",
      "severity": "medium",
      "category": "performance",
      "description": "API rate limiting or reconciliation issues",
      "suggestions": [
        "Implement exponential backoff",
        "Check reconciliation frequency",
        "Review event triggers"
      ]
    }
  ],
  "warning_patterns": [
    {
      "name": "Slow Reconciliation",
      "pattern": "reconciliation took.*[5-9][0-9]s|reconciliation took.*[0-9]+m",
      "severity": "medium",
      "category": "performance",
      "description": "Reconciliation taking longer than expected",
      "suggestions": [
        "Profile reconciliation logic",
        "Check external API calls",
        "Review resource processing efficiency"
      ]
    },
    {
      "name": "Large Queue Depth",
      "pattern": "queue depth.*[1-9][0-9][0-9]+|queue.*behind",
      "severity": "medium",
      "category": "performance",
      "description": "Controller queue growing large",
      "suggestions": [
        "Increase worker count",
        "Optimize reconciliation logic",
        "Check for recursive requeues"
      ]
    },
    {
      "name": "Resource Conflicts",
      "pattern": "conflict|resource version|optimistic lock",
      "severity": "low",
      "category": "concurrency",
      "description": "Resource update conflicts",
      "suggestions": [
        "Implement retry with exponential backoff",
        "Review concurrent reconciliation logic",
        "Check for race conditions"
      ]
    }
  ],
  "success_patterns": [
    {
      "name": "Successful Reconciliation",
      "pattern": "successfully reconciled|reconciliation completed",
      "category": "success",
      "description": "Normal reconciliation completion"
    },
    {
      "name": "Resource Created",
      "pattern": "created.*successfully|resource created",
      "category": "success", 
      "description": "Resource creation succeeded"
    },
    {
      "name": "Controller Started",
      "pattern": "controller.*started|manager.*started|starting.*manager",
      "category": "lifecycle",
      "description": "Controller initialization successful"
    }
  ],
  "performance_patterns": [
    {
      "name": "Reconciliation Duration",
      "pattern": "reconciliation took ([0-9.]+)(ms|s|m)",
      "metric": "duration",
      "category": "performance"
    },
    {
      "name": "Queue Metrics",
      "pattern": "queue depth: ([0-9]+)|items in queue: ([0-9]+)",
      "metric": "queue_depth", 
      "category": "performance"
    },
    {
      "name": "API Call Latency",
      "pattern": "api call took ([0-9.]+)(ms|s)",
      "metric": "api_latency",
      "category": "performance"
    }
  ],
  "openstack_patterns": [
    {
      "name": "Nova Service Error",
      "pattern": "nova.*error|compute.*failed|instance.*error",
      "severity": "high",
      "category": "openstack",
      "description": "Nova/Compute service issues",
      "suggestions": [
        "Check Nova service logs",
        "Verify compute node health",
        "Check instance scheduling"
      ]
    },
    {
      "name": "Keystone Auth Error", 
      "pattern": "keystone.*unauthorized|auth.*failed|invalid.*credentials",
      "severity": "high",
      "category": "openstack",
      "description": "Authentication/authorization issues with Keystone",
      "suggestions": [
        "Verify service credentials",
        "Check Keystone service health",
        "Review user permissions"
      ]
    },
    {
      "name": "Database Connection",
      "pattern": "database.*error|sql.*error|connection.*refused.*mysql",
      "severity": "high",
      "category": "openstack",
      "description": "Database connectivity issues",
      "suggestions": [
        "Check database service health",
        "Verify connection credentials",
        "Check network connectivity"
      ]
    }
  ]
}